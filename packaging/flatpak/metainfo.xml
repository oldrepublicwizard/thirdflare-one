<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.cloudflare_one_gui_linux.CloudflareOneGui</id>
  <name>ThirdFlare One</name>
  <summary>Unofficial Cloudflare One client via warp-cli</summary>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <description>
    <p>
      ThirdFlare One wraps the host Cloudflare WARP client (warp-cli) with a local API
      and optional browser UI. The Flatpak bundles Node and calls warp-cli on the host
      through flatpak-spawn --host. Cloudflare WARP must already be installed on the system.
    </p>
  </description>
  <launchable type="desktop-id">io.github.cloudflare_one_gui_linux.CloudflareOneGui.desktop</launchable>
  <url type="homepage">https://github.com/oldrepublicwizard/thirdflare-one</url>
  <developer id="io.github.cloudflare_one_gui_linux">
    <name>ThirdFlare One contributors</name>
  </developer>
  <categories>
    <category>Network</category>
    <category>Utility</category>
  </categories>
  <releases>
    <release version="0.1.0" date="2026-07-17">
      <description>
        <p>Initial packaging release.</p>
      </description>
    </release>
  </releases>
  <content_rating type="oars-1.1">
