[Desktop Entry]
Type=Application
Name=ThirdFlare One
Comment=Unofficial cross-platform Cloudflare One client for warp-cli
Exec=thirdflare-one
Icon=thirdflare
Terminal=false
Categories=Network;
Keywords=Cloudflare;WARP;Zero Trust;ThirdFlare One;VPN;DNS;
StartupNotify=true
Actions=Connect;Disconnect;Toggle;Status;Tray;

[Desktop Action Connect]
Name=Connect WARP
Exec=thirdflare-one --connect
Icon=thirdflare

[Desktop Action Disconnect]
Name=Disconnect WARP
Exec=thirdflare-one --disconnect
Icon=thirdflare

[Desktop Action Toggle]
Name=Toggle WARP
Exec=thirdflare-one --toggle
Icon=thirdflare

[Desktop Action Status]
Name=Show WARP Status
Exec=thirdflare-one
Icon=thirdflare

[Desktop Action Tray]
Name=Start Tray Menu
Exec=thirdflare-one --tray
Icon=thirdflare
