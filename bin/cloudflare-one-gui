#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
APP_NAME="cloudflare-one-gui"
BASE_PORT="${CLOUDFLARE_ONE_GUI_PORT:-4173}"
PORT="$BASE_PORT"
HOST="127.0.0.1"
URL="http://${HOST}:${PORT}"
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}/${APP_NAME}"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/${APP_NAME}"
PID_FILE="${RUNTIME_DIR}/server.pid"
LOG_FILE="${CACHE_DIR}/server.log"

mkdir -p "$RUNTIME_DIR" "$CACHE_DIR"

# Prefer a bundled Node (AppImage) when present.
if [[ -x "${APP_DIR}/runtime/node/bin/node" ]]; then
  NODE_BIN="${APP_DIR}/runtime/node/bin/node"
elif [[ -n "${CLOUDFLARE_ONE_GUI_NODE:-}" ]]; then
  NODE_BIN="$CLOUDFLARE_ONE_GUI_NODE"
else
  NODE_BIN="node"
fi

run_warp_cli() {
  local bin="${WARP_CLI:-warp-cli}"
  if [[ -n "${FLATPAK_ID:-}" && "$bin" == "warp-cli" ]] && command -v flatpak-spawn >/dev/null 2>&1; then
    flatpak-spawn --host -- warp-cli "$@"
  else
    "$bin" "$@"
  fi
}

usage() {
  cat <<USAGE
Cloudflare One GUI

Usage:
  cloudflare-one-gui            Start/reuse the local server and open the GUI
  cloudflare-one-gui --no-open  Start/reuse the server and print the URL
  cloudflare-one-gui --status   Print server status
  cloudflare-one-gui --stop     Stop the managed server
  cloudflare-one-gui --connect  Run warp-cli connect and show the GUI
  cloudflare-one-gui --disconnect
                                Run warp-cli disconnect and show the GUI
  cloudflare-one-gui --toggle   Connect if disconnected, otherwise disconnect
  cloudflare-one-gui --warp-status
                                Print warp-cli status
  cloudflare-one-gui --tray     Start the optional tray menu
  cloudflare-one-gui --help     Show this help
USAGE
}

is_running() {
  [[ -f "$PID_FILE" ]] || return 1
  local pid
  pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

health_ok() {
  "$NODE_BIN" "$APP_DIR/scripts/health-check.mjs" "$URL/api/health" >/dev/null 2>&1
}

set_port() {
  PORT="$1"
  URL="http://${HOST}:${PORT}"
}

port_open() {
  "$NODE_BIN" "$APP_DIR/scripts/port-open.mjs" "$HOST" "$PORT" >/dev/null 2>&1
}

choose_port() {
  local candidate
  for candidate in $(seq "$BASE_PORT" "$((BASE_PORT + 30))"); do
    set_port "$candidate"
    if health_ok; then
      return 0
    fi
    if ! port_open; then
      return 0
    fi
  done

  echo "No available local port found from $BASE_PORT to $((BASE_PORT + 30))." >&2
  return 1
}

start_server() {
  choose_port

  if health_ok; then
    return 0
  fi

  if is_running && health_ok; then
    return 0
  fi

  if is_running; then
    kill "$(cat "$PID_FILE")" 2>/dev/null || true
  fi

  : > "$LOG_FILE"
  (
    cd "$APP_DIR"
    if command -v setsid >/dev/null 2>&1; then
      nohup setsid env PORT="$PORT" "$NODE_BIN" "$APP_DIR/server.js" >>"$LOG_FILE" 2>&1 &
    else
      nohup env PORT="$PORT" "$NODE_BIN" "$APP_DIR/server.js" >>"$LOG_FILE" 2>&1 &
    fi
    echo "$!" > "$PID_FILE"
  )

  for _ in $(seq 1 80); do
    if health_ok; then
      return 0
    fi
    sleep 0.1
  done

  echo "Cloudflare One GUI server did not become healthy. Log: $LOG_FILE" >&2
  if is_running; then
    kill "$(cat "$PID_FILE")" 2>/dev/null || true
    rm -f "$PID_FILE"
  fi
  return 1
}

stop_server() {
  if is_running; then
    kill "$(cat "$PID_FILE")"
    rm -f "$PID_FILE"
    echo "Stopped Cloudflare One GUI server."
  else
    echo "Cloudflare One GUI server is not running."
  fi
}

open_gui() {
  if command -v firefox >/dev/null 2>&1; then
    firefox --new-window "$URL" >/dev/null 2>&1 &
  else
    xdg-open "$URL" >/dev/null 2>&1 &
  fi
}

notify() {
  local title="$1"
  local body="$2"
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "$title" "$body" --icon="$APP_DIR/assets/cloudflare-one-gui.svg" >/dev/null 2>&1 || true
  fi
}

warp_status() {
  run_warp_cli --no-ansi --no-paginate status
}

run_warp_action() {
  local verb="$1"
  local output
  if output="$(run_warp_cli --no-ansi --no-paginate "$verb" 2>&1)"; then
    notify "Cloudflare One GUI" "warp-cli $verb completed"
    printf '%s\n' "$output"
  else
    notify "Cloudflare One GUI" "warp-cli $verb failed"
    printf '%s\n' "$output" >&2
    return 1
  fi
}

toggle_warp() {
  local status
  status="$(warp_status 2>&1 || true)"
  if printf '%s\n' "$status" | grep -qi 'Status update: Connected'; then
    run_warp_action disconnect
  else
    run_warp_action connect
  fi
}

case "${1:-}" in
  --help|-h)
    usage
    ;;
  --status)
    if is_running && health_ok; then
      echo "Cloudflare One GUI is running at $URL"
    else
      echo "Cloudflare One GUI is not running."
      exit 1
    fi
    ;;
  --stop)
    stop_server
    ;;
  --connect)
    run_warp_action connect
    start_server
    open_gui
    ;;
  --disconnect)
    run_warp_action disconnect
    start_server
    open_gui
    ;;
  --toggle)
    toggle_warp
    start_server
    open_gui
    ;;
  --warp-status)
    warp_status
    ;;
  --tray)
    exec "$APP_DIR/bin/cloudflare-one-tray"
    ;;
  --no-open)
    start_server
    echo "$URL"
    ;;
  "")
    start_server
    open_gui
    echo "Cloudflare One GUI opened at $URL"
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
