#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
LAUNCHER="$APP_DIR/bin/thirdflare"
ICON="$APP_DIR/assets/thirdflare.svg"

usage() {
  cat <<USAGE
ThirdFlare One tray

Usage:
  thirdflare-one-tray          Start a yad-based tray menu
  thirdflare-one-tray --status Print tray availability and WARP status
  thirdflare-one-tray --help   Show this help
USAGE
}

tray_available() {
  command -v yad >/dev/null 2>&1 && [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]
}

status_text() {
  "$LAUNCHER" --warp-status 2>&1 | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g; s/[[:space:]]$//'
}

notify_status() {
  local status
  status="$(status_text)"
  printf '%s\n' "$status"
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "ThirdFlare One" "$status" --icon="$ICON" >/dev/null 2>&1 || true
  fi
}

run_tray() {
  if ! tray_available; then
    echo "A yad tray requires yad plus DISPLAY or WAYLAND_DISPLAY." >&2
    return 1
  fi

  local menu
  menu="Open GUI!$LAUNCHER|Connect WARP!$LAUNCHER --connect|Disconnect WARP!$LAUNCHER --disconnect|Toggle WARP!$LAUNCHER --toggle|Show Status!$APP_DIR/bin/thirdflare-tray --status|Quit!quit"

  yad \
    --notification \
    --image="$ICON" \
    --text="ThirdFlare One - $(status_text)" \
    --command="$LAUNCHER" \
    --menu="$menu"
}

case "${1:-}" in
  --help|-h)
    usage
    ;;
  --status)
    notify_status
    ;;
  "")
    run_tray
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
